# Copy this file to `.env` (or export these as real environment variables)
# NEVER commit a file containing your actual secrets.

# --- Database ---
# Local development uses embedded H2 by default.
# Override these for Supabase/PostgreSQL in production.
DB_URL=jdbc:postgresql://db.<your-project-ref>.supabase.co:5432/postgres?sslmode=require
DB_USERNAME=sa
DB_PASSWORD=<your Supabase password>

# --- NVIDIA NIM (build.nvidia.com) ---
NVIDIA_API_KEY=local-dev-placeholder
NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# --- JWT ---
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
JWT_EXPIRATION_MS=86400000

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173
